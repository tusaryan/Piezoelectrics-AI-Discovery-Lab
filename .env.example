# ============================================
# Piezo.AI v2.1.0 — Environment Variables (Example)
# ============================================
# Copy this to .env and fill in your values.

# Application
APP_VERSION=2.1.0

# Database
DATABASE_URL=postgresql+asyncpg://piezo:piezo@localhost:5432/piezo_ai

# API
CORS_ORIGINS=["http://localhost:3000"]
API_SECRET_KEY=change-me-to-random-256-bit-secret

# ML Artifact Paths
MODEL_ARTIFACTS_PATH=./resources/trained-models
TRAINING_ARTIFACTS_PATH=./resources/training-artifacts

# Feature flags
ENABLE_COMPOSITE_MODULE=true
ENABLE_HARDNESS_MODULE=true
ENABLE_GNN_MODULE=false
ENABLE_AGENT_MODULE=false

# LLM (optional)
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Voice (optional — deferred)
ENABLE_VOICE=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_VERSION=2.1.0
NEXT_PUBLIC_ENABLE_COMPOSITE=true
NEXT_PUBLIC_ENABLE_HARDNESS=true
NEXT_PUBLIC_ENABLE_GNN=false
NEXT_PUBLIC_ENABLE_AGENT=false

# Developer Info
NEXT_PUBLIC_DEV_GITHUB=https://github.com/yourusername
NEXT_PUBLIC_DEV_LINKEDIN=https://linkedin.com/in/yourusername
