# ============================================
# Piezo.AI v2 — Environment Variables
# ============================================

# Database (PostgreSQL — local or Docker)
DATABASE_URL=postgresql+asyncpg://piezo:piezo@localhost:5432/piezo_ai

# ML
MODEL_ARTIFACTS_PATH=data/models

# API
CORS_ORIGINS=["http://localhost:3000"]
API_SECRET_KEY=change-me-to-random-256-bit-secret

# Feature flags (true/false)
ENABLE_COMPOSITE_MODULE=true
ENABLE_HARDNESS_MODULE=true
ENABLE_GNN_MODULE=false
ENABLE_AGENT_MODULE=false

# Agent (Phase 5) — Model Agnostic LLM
# Supported providers: openai, anthropic, google, ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
CHROMA_PERSIST_PATH=data/chroma

# Voice Interaction (optional)
ENABLE_VOICE=false
VOICE_PROVIDER=openai
OPENAI_REALTIME_API_KEY=
GOOGLE_LIVE_API_KEY=

# Frontend (prefix with NEXT_PUBLIC_ for client-side access)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ENABLE_COMPOSITE=true
NEXT_PUBLIC_ENABLE_HARDNESS=true
NEXT_PUBLIC_ENABLE_GNN=false
NEXT_PUBLIC_ENABLE_AGENT=false
NEXT_PUBLIC_ENABLE_VOICE=false
